{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "ES2022"],
		"module": "ESNext",
		"noEmit": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"jsx": "react-jsx",
		"jsxImportSource": "jsx-dom",
		"strict": true,
		// todo:
		"strictNullChecks": false
	}
}
