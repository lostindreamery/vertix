{
	"$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
	"root": false,
	"extends": "//",
	"linter": {
		"rules": {
			"style": {
				"useConst": "off"
			},
			"suspicious": {
				// "noVar": "warn"
			},
			"correctness": {
				"noUnusedVariables": "info",
				"useParseIntRadix": "off"
			}
		}
	}
}
